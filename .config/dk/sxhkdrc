# dmenu
super + p
    dmenu_run -nb '#000000' -nf '#ffffff' -sb '#4ad66d' -sf '#000000' -fn 'CommitMono:size=12:bold' -l 0

# screenshot
super + shift + s 
    scrot -s ~/images/screenshots/%Y-%m-%d-%H%M%S.png -e 'xclip -selection clipboard -target image/png -i $f'

# focus next or previous window
super + {j,k}
	dkcmd win focus {next,prev}

# move window
super + shift + {h,j,k,l}
	dkcmd win resize {x=-30,y=+30,y=-30,x=+30}

# resize window
super + ctrl + {h,j,k,l}
	dkcmd win resize {w=-30,h=+30,h=-30,w=+30}

# view, send, or follow to the workspaces
super + {_,shift + ,ctrl + }{a, s, d, w}
	dkcmd ws {view,send,follow} {1-3, 4}

# close window, swap tiled window in/out of master, cycle tiled windows in place
super + shift + {q,space,c}
	dkcmd win {kill,swap,cycle}

# change active workspace layout or cycle between them
super + alt + {t,m,g,s,u,c}
	dkcmd set layout {tile,mono,grid,spiral,tstack,cycle}

# change number of windows in master or first stack
super + {_,shift + }{i,d}
	dkcmd set {master,stack} {+1,-1}

# change gap width: fix?
super + {plus,minus,backspace}
	dkcmd set gap {+4,-4,4}

# toggle borders
super + {shift} + b
    dkcmd set border width {8,0}

# Reload sxhkd
super + shift + x
	pkill -USR1 -x sxhkd

# Reload dk
super + shift + r
	dkcmd restart
